# Database (local dev — production uses a single JDBC URL with embedded credentials)
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/wordgame
QUARKUS_DATASOURCE_USERNAME=mainuser
QUARKUS_DATASOURCE_PASSWORD=change-me

# HTTP
QUARKUS_HTTP_PORT=8081

# CORS (comma-separated origins for direct browser clients)
CORS_ORIGINS=http://localhost:3000

# OAuth / OIDC — introspects opaque BFF service tokens from CustomAuth
OIDC_AUTH_SERVER_URL=https://customauth.fly.dev/
OIDC_CLIENT_ID=wordgamebff
OIDC_CLIENT_SECRET=
OIDC_TOKEN_AUDIENCE=resource_server
BFF_CLIENT_ID=wordgamebff
